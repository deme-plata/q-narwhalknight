# Q-NarwhalKnight Environment Configuration
# Copy this file to .env and fill in your actual values

# Stripe Payment API Key (for USD wallet functionality)
# Get your key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database Paths (optional, defaults provided)
# Q_DB_PATH=./data
# Q_HOT_DB_PATH=./data-hot

# API Server Configuration (optional)
# Q_API_PORT=8001
# Q_API_HOST=127.0.0.1

# Network Configuration (optional)
# Q_P2P_PORT=9001
# Q_TOR_ENABLED=true

# Logging Level (optional)
# RUST_LOG=info
