[size=14pt][b][color=#FF00FF]V2.2.0 TECHNICAL CHANGES[/color][/b][/size]

[b]Files Modified:[/b]

[b]1. crates/q-storage/src/lib.rs:899-927[/b]
[code]/// v2.2.0: CRITICAL DATA INTEGRITY FIX
/// Acquire global write lock BEFORE any Transaction writes to prevent race conditions.
///
/// Race condition scenario WITHOUT this lock:
/// 1. Thread A: reads height pointer = 100
/// 2. Thread B: reads height pointer = 100
/// 3. Thread A: writes blocks 101-200, sets pointer = 200
/// 4. Thread B: writes blocks 101-150, sets pointer = 150
/// 5. RESULT: Pointer regresses from 200 to 150, blocks 151-200 become orphans!
///
pub async fn acquire_global_write_lock(&self) -> tokio::sync::MutexGuard<'_, ()> {
    self.global_write_lock.lock().await
}[/code]

[b]2. crates/q-storage/src/turbo_sync.rs:2724-2732[/b]
[code]// v2.2.0: CRITICAL DATA INTEGRITY FIX
// Acquire global write lock BEFORE any Transaction writes to prevent race conditions.
let _global_guard = self.storage.acquire_global_write_lock().await;
debug!("Legacy mode acquired global write lock for {} blocks", blocks.len());[/code]

[b]3. crates/q-storage/src/turbo_sync.rs:2821-2859[/b]
[code]// v2.2.0: TOCTOU Race Elimination
// Re-read current height UNDER LOCK to prevent time-of-check/time-of-use race
let _global_guard = self.storage.acquire_global_write_lock().await;
let actual_current = self.storage.get_latest_qblock_height().await.ok().flatten().unwrap_or(0);

if highest_contiguous > actual_current {
    let tx = self.storage.begin_transaction().await?;
    let latest_height_bytes = highest_contiguous.to_be_bytes().to_vec();
    tx.put("blocks", b"qblock:latest", &latest_height_bytes).await?;
    tx.commit().await?;

    // WAL sync AFTER pointer update for durability
    self.storage.sync_wal().await?;
}[/code]

