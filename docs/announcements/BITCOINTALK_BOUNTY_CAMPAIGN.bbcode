[size=16pt][b][color=#22c55e]QUICK START[/color][/b][/size]

[code]
# 1. Register for the bounty program
Visit: https://bounty.quillon.xyz/register

# 2. Download and run a node (Linux)
wget https://quillon.xyz/downloads/q-api-server-linux-x86_64
chmod +x q-api-server-linux-x86_64
./q-api-server-linux-x86_64 --port 9090 --p2p-port 9001

# 3. Download and run a node (Windows)
Download: https://quillon.xyz/downloads/q-narwhalknight-windows-x64.zip
Extract and run: q-api-server.exe --port 9090 --p2p-port 9001

# 4. Access the wallet UI
Visit: https://quillon.xyz

# 5. Track your bounty progress
Visit: https://bounty.quillon.xyz/dashboard
[/code]

