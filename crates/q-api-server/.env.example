# Q-NarwhalKnight API Server Environment Variables

# Stripe Payment Integration (for USD Wallet features)
# Get your API keys from: https://dashboard.stripe.com/apikeys
# For testing, use test keys starting with "sk_test_"
# For production, use live keys starting with "sk_live_"
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Example:
# STRIPE_SECRET_KEY=sk_test_51ABC123def456GHI789jkl012MNO345pqr678STU901vwx234YZA567bcd890efg123HIJ456klm789NOP012qrs345TUV678wxy901
