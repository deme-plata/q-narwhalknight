/// Comprehensive Node Inspection API
/// Provides detailed visibility into individual node operations and network-wide stats
use axum::{extract::{State, Path, Query}, response::Json, routing::get, Router};
use serde::{Deserialize, Serialize};
use std::collections::{HashMap, BTreeMap};
use chrono::{DateTime, Utc};

/// Comprehensive node information
#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NodeInfo {
    /// Node identification
    pub node_id: String,
    pub address: String,
    pub version: String,
    pub start_time: DateTime<Utc>,
    pub uptime_seconds: u64,
    
    /// Node status
    pub status: NodeStatus,
    pub sync_status: SyncStatus,
    pub consensus_participation: f64,
    
    /// Network information
    pub network: NetworkInfo,
    
    /// Performance metrics
    pub performance: NodePerformance,
    
    /// Resource utilization
    pub resources: ResourceUtilization,
    
    /// Blockchain/DAG state
    pub blockchain_state: BlockchainState,
    
    /// Configuration
    pub config: NodeConfiguration,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub enum NodeStatus {
    Starting,
    Syncing,
    Active,
    Degraded,
    Offline,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct SyncStatus {
    pub is_synced: bool,
    pub sync_progress: f64,
    pub blocks_behind: u64,
    pub estimated_sync_time: Option<u64>,
    pub sync_peers: Vec<String>,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NetworkInfo {
    pub peer_count: u32,
    pub inbound_peers: u32,
    pub outbound_peers: u32,
    pub banned_peers: u32,
    pub network_traffic: NetworkTraffic,
    pub connection_stats: ConnectionStats,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NetworkTraffic {
    pub bytes_sent_total: u64,
    pub bytes_received_total: u64,
    pub bytes_sent_per_sec: u64,
    pub bytes_received_per_sec: u64,
    pub messages_sent_total: u64,
    pub messages_received_total: u64,
    pub messages_sent_per_sec: u64,
    pub messages_received_per_sec: u64,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct ConnectionStats {
    pub successful_connections: u64,
    pub failed_connections: u64,
    pub dropped_connections: u64,
    pub avg_connection_time: u64,
    pub connection_errors: HashMap<String, u64>,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NodePerformance {
    /// Transaction processing
    pub transactions_processed: u64,
    pub transactions_per_second: f64,
    pub avg_transaction_time: u64,
    
    /// Consensus metrics
    pub vertices_created: u64,
    pub certificates_issued: u64,
    pub votes_cast: u64,
    pub consensus_rounds_participated: u64,
    
    /// Verification metrics
    pub signatures_verified: u64,
    pub vdf_computations: u64,
    pub quantum_verifications: u64,
    
    /// Error rates
    pub error_rate: f64,
    pub failed_verifications: u64,
    pub byzantine_flags: u32,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct ResourceUtilization {
    /// CPU usage
    pub cpu_usage_percent: f64,
    pub cpu_cores: u32,
    pub load_average: [f64; 3],
    
    /// Memory usage
    pub memory_used_bytes: u64,
    pub memory_total_bytes: u64,
    pub memory_usage_percent: f64,
    pub swap_used_bytes: u64,
    pub swap_total_bytes: u64,
    
    /// Disk usage
    pub disk_used_bytes: u64,
    pub disk_total_bytes: u64,
    pub disk_usage_percent: f64,
    pub disk_io_read_bytes: u64,
    pub disk_io_write_bytes: u64,
    
    /// Network I/O
    pub network_io_bytes_sent: u64,
    pub network_io_bytes_received: u64,
    
    /// Open file descriptors
    pub open_files: u32,
    pub max_files: u32,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct BlockchainState {
    /// Current blockchain/DAG height
    pub current_height: u64,
    pub current_round: u64,
    pub best_block_hash: String,
    
    /// Mempool information
    pub mempool_size: u32,
    pub mempool_bytes: u64,
    pub pending_transactions: u32,
    
    /// Consensus state
    pub consensus_state: String,
    pub validator_status: Option<ValidatorStatus>,
    
    /// Chain statistics
    pub total_transactions: u64,
    pub average_block_time: f64,
    pub chain_work: String,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct ValidatorStatus {
    pub is_validator: bool,
    pub stake_amount: Option<u64>,
    pub voting_power: Option<f64>,
    pub reputation_score: f64,
    pub slashing_events: u32,
    pub rewards_earned: u64,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NodeConfiguration {
    /// Network configuration
    pub listen_port: u16,
    pub max_peers: u32,
    pub rpc_enabled: bool,
    pub rpc_port: u16,
    
    /// Consensus configuration
    pub consensus_algorithm: String,
    pub block_time_ms: u64,
    pub max_block_size: u64,
    
    /// Quantum configuration
    pub quantum_features_enabled: bool,
    pub post_quantum_crypto: bool,
    pub vdf_difficulty: u32,
    
    /// Logging and debugging
    pub log_level: String,
    pub debug_mode: bool,
    pub metrics_enabled: bool,
}

/// Detailed peer information
#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct DetailedPeerInfo {
    pub peer_id: String,
    pub address: String,
    pub connection_time: DateTime<Utc>,
    pub connection_type: ConnectionType,
    pub protocol_version: String,
    pub user_agent: String,
    
    /// Connection quality
    pub latency_ms: u64,
    pub bandwidth_mbps: f64,
    pub connection_stability: f64,
    
    /// Sync status
    pub height: u64,
    pub is_synced: bool,
    pub blocks_ahead: i64,
    
    /// Traffic stats
    pub bytes_sent: u64,
    pub bytes_received: u64,
    pub messages_sent: u64,
    pub messages_received: u64,
    
    /// Reputation
    pub reputation_score: f64,
    pub misbehavior_score: u32,
    pub ban_status: BanStatus,
    
    /// Capabilities
    pub supported_protocols: Vec<String>,
    pub services: Vec<String>,
    pub quantum_capable: bool,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub enum ConnectionType {
    Inbound,
    Outbound,
    Manual,
    Bootstrap,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub enum BanStatus {
    Active,
    Banned { until: DateTime<Utc>, reason: String },
    None,
}

/// Historical performance data
#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct PerformanceHistory {
    pub timeframe: String,
    pub data_points: Vec<PerformanceDataPoint>,
    pub summary_stats: PerformanceSummary,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct PerformanceDataPoint {
    pub timestamp: DateTime<Utc>,
    pub tps: f64,
    pub latency_ms: u64,
    pub cpu_usage: f64,
    pub memory_usage: f64,
    pub network_io_mbps: f64,
    pub active_connections: u32,
    pub consensus_participation: f64,
}

#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct PerformanceSummary {
    pub avg_tps: f64,
    pub max_tps: f64,
    pub avg_latency: u64,
    pub min_latency: u64,
    pub max_latency: u64,
    pub uptime_percentage: f64,
    pub error_rate: f64,
}

/// Log entry structure
#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct LogEntry {
    pub timestamp: DateTime<Utc>,
    pub level: String,
    pub module: String,
    pub message: String,
    pub fields: HashMap<String, serde_json::Value>,
}

/// Query parameters for logs
#[derive(Deserialize)]
pub struct LogQuery {
    pub level: Option<String>,
    pub module: Option<String>,
    pub since: Option<DateTime<Utc>>,
    pub limit: Option<u32>,
    pub search: Option<String>,
}

/// Network-wide statistics
#[derive(Serialize, Deserialize, Debug, Clone)]
pub struct NetworkWideStats {
    pub total_nodes: u32,
    pub active_nodes: u32,
    pub consensus_participating_nodes: u32,
    pub network_hash_rate: f64,
    pub total_stake: u64,
    pub network_version_distribution: HashMap<String, u32>,
    pub geographic_distribution: HashMap<String, u32>,
    pub average_node_uptime: f64,
    pub network_health_score: f64,
}

pub fn create_node_routes() -> Router<std::sync::Arc<crate::AppState>> {
    Router::new()
        // Node information
        .route("/api/v1/node/info", get(get_node_info))
        .route("/api/v1/node/status", get(get_node_status))
        .route("/api/v1/node/config", get(get_node_config))
        .route("/api/v1/node/performance", get(get_node_performance))
        
        // Resource monitoring
        .route("/api/v1/node/resources", get(get_resource_utilization))
        .route("/api/v1/node/resources/history", get(get_resource_history))
        
        // Network connectivity
        .route("/api/v1/node/peers", get(get_peers))
        .route("/api/v1/node/peer/:peer_id", get(get_peer_detail))
        .route("/api/v1/node/connections", get(get_connection_stats))
        .route("/api/v1/node/network-traffic", get(get_network_traffic))
        
        // Logging and debugging
        .route("/api/v1/node/logs", get(get_logs))
        .route("/api/v1/node/logs/tail", get(tail_logs))
        .route("/api/v1/node/debug", get(get_debug_info))
        
        // Performance analysis
        .route("/api/v1/node/performance/history", get(get_performance_history))
        .route("/api/v1/node/performance/benchmark", get(run_performance_benchmark))
        
        // Network-wide visibility
        .route("/api/v1/network/stats", get(get_network_wide_stats))
        .route("/api/v1/network/nodes", get(get_all_nodes))
        .route("/api/v1/network/node-health", get(get_network_health_detailed))
        
        // Advanced diagnostics
        .route("/api/v1/node/diagnostics", get(run_diagnostics))
        .route("/api/v1/node/trace/:trace_id", get(get_trace_data))
        .route("/api/v1/node/metrics/prometheus", get(get_prometheus_metrics))
}

