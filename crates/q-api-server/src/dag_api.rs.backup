}

/// Get consensus progression analysis
async fn get_consensus_progression(State(state): State<std::sync::Arc<crate::AppState>>) -> Json<ConsensusProgression> {
    let mut rounds = BTreeMap::new();
    rounds.insert(12343, RoundInfo {
        round: 12343,
        status: RoundStatus::Completed,
        vertex_count: 4,
        transaction_count: 100,
        start_time: Utc::now(),
        completion_time: Some(Utc::now()),
        quantum_anchor: Some("anchor_vertex_123".to_string()),
        vdf_computation_time: Some(1000),
        byzantine_faults: 0,
    });
    
    Json(ConsensusProgression {
        rounds,
        chain_progression: vec![],
        performance_history: vec![],
        network_health: NetworkHealth {
            connected_peers: 3,
            total_peers: 4,
            partition_risk: 0.1,
            byzantine_tolerance: 0.33,
            consensus_participation: 0.95,
            network_latency_ms: 50,
        },
    })
}

