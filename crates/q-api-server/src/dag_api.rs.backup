/// Get network topology
async fn get_network_topology(State(state): State<std::sync::Arc<crate::AppState>>) -> Json<NetworkTopology> {
    let mut peers = HashMap::new();
    peers.insert("alice".to_string(), PeerInfo {
        node_id: "alice_123".to_string(),
        address: "127.0.0.1:8080".to_string(),
        last_seen: Utc::now(),
        version: "0.1.0".to_string(),
        stake: Some(1000),
        reputation_score: 0.95,
        byzantine_flags: 0,
        performance_stats: PeerPerformance {
            vertices_created: 1000,
            certificates_issued: 800,
            uptime_percentage: 0.999,
            avg_response_time: 50,
            bandwidth_utilization: 0.45,
        },
    });
    
    let mut connections = HashMap::new();
    connections.insert("alice".to_string(), vec!["bob".to_string(), "charlie".to_string()]);
    
    Json(NetworkTopology {
        peers,
        connections,
        diameter: 2,
        clustering_coefficient: 0.75,
        centrality: HashMap::new(),
        partitions: vec![],
    })
}

