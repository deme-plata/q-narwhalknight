[Unit]
Description=q-flux High-Performance Reverse Proxy (Delta)
After=network.target q-api-server.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/orobit/shared/q-narwhalknight/q-flux -c /opt/orobit/shared/q-narwhalknight/q-flux-delta.toml
Restart=always
RestartSec=3
LimitNOFILE=1048576
WorkingDirectory=/opt/orobit/shared/q-narwhalknight
Environment="RUST_LOG=info"

# Memory limits — 31GB Delta, cap at 4GB
MemoryMax=4G
MemoryHigh=3G

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/orobit/shared/q-narwhalknight /var/log
ReadOnlyPaths=/etc/letsencrypt

[Install]
WantedBy=multi-user.target
