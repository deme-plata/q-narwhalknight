# Quantum Wallet Environment Configuration

# API Server URL
# For local development, use: http://localhost:8080/api
# For production behind nginx, use: /api
VITE_API_URL=http://localhost:8080/api

# Stripe Payment Integration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# For testing, use test keys starting with "pk_test_"
# For production, use live keys starting with "pk_live_"
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
