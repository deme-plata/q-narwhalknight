{
  "expo": {
    "name": "Quillon Wallet",
    "slug": "quillon-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "qnk",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121218"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.quillon.wallet",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes for receiving payments",
        "NSFaceIDUsageDescription": "Use Face ID to unlock your wallet"
      }
    },
    "android": {
      "package": "xyz.quillon.wallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121218"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Quillon Wallet to use the camera to scan QR codes."
        }
      ],
      "expo-notifications",
      "@sentry/react-native",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "quillon-wallet"
      }
    }
  }
}
