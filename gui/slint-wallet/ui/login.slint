import { Theme, QButton, QInput, Card, GradientCard, Icon } from "theme.slint";

// Action card: large clickable tile with icon, title, description, and accent stripe.
component ActionCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <image> icon-source;
    in property <color> accent;
    in property <bool> selected: false;
    callback clicked;

    height: 132px;
    border-radius: Theme.radius-lg;
    background: selected
        ? root.accent.with-alpha(0.10)
        : (touch.has-hover ? Theme.bg-hover : Theme.bg-card);
    border-width: 1px;
    border-color: selected ? root.accent.with-alpha(0.5) : Theme.border;
    drop-shadow-blur: touch.has-hover ? Theme.shadow-md-blur : Theme.shadow-sm-blur;
    drop-shadow-offset-y: touch.has-hover ? 4px : 1px;
    drop-shadow-color: #000000.with-alpha(0.35);
    animate background, border-color, drop-shadow-blur, drop-shadow-offset-y { duration: 150ms; }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    // Accent stripe on left
    Rectangle {
        x: 0;
        y: 0;
        width: 4px;
        height: parent.height;
        background: root.accent;
        border-top-left-radius: Theme.radius-lg;
        border-bottom-left-radius: Theme.radius-lg;
    }

    HorizontalLayout {
        padding-left: Theme.spacing-lg;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-md;
        padding-bottom: Theme.spacing-md;
        spacing: Theme.spacing-md;

        // Icon tile
        Rectangle {
            width: 56px;
            height: 56px;
            border-radius: Theme.radius-md;
            background: root.accent.with-alpha(0.12);
            y: (parent.height - 56px) / 2;

            Icon {
                source: root.icon-source;
                icon-color: root.accent;
                width: 28px;
                height: 28px;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 4px;
            horizontal-stretch: 1;

            Text {
                text: root.title;
                color: Theme.text-primary;
                font-size: Theme.font-lg;
                font-weight: 700;
            }
            Text {
                text: root.description;
                color: Theme.text-secondary;
                font-size: Theme.font-sm;
                wrap: word-wrap;
            }
        }

        // Chevron
        VerticalLayout {
            alignment: center;
            Icon {
                source: @image-url("icons/arrow-right.svg");
                icon-color: root.accent.with-alpha(0.7);
                width: Theme.icon-md;
                height: Theme.icon-md;
            }
        }
    }
}

export component LoginScreen inherits Rectangle {
    in-out property <string> mnemonic-text: "";
    in-out property <string> server-url: "https://quillon.xyz";
    in-out property <string> generated-mnemonic: "";
    in-out property <string> error-message: "";
    in-out property <bool> show-create-view: false;
    in property <bool> oauth-server-running: true;
    in property <int> oauth-port: 17655;
    in property <string> wallet-version: "v10.9.23";

    // Internal: which expanded panel is showing (0=none, 1=import, 2=oauth)
    in-out property <int> active-action: 0;

    callback create-wallet();
    callback import-wallet(string);
    callback confirm-created();
    callback open-oauth-browser();

    background: Theme.bg-primary;

    // Subtle radial-gradient corner accents
    Rectangle {
        x: -120px;
        y: -120px;
        width: 360px;
        height: 360px;
        border-radius: 180px;
        background: Theme.accent-cyan.with-alpha(0.06);
    }
    Rectangle {
        x: parent.width - 240px;
        y: parent.height - 240px;
        width: 360px;
        height: 360px;
        border-radius: 180px;
        background: Theme.accent-purple.with-alpha(0.05);
    }

    Flickable {
        VerticalLayout {
            alignment: start;
            padding-left: Theme.spacing-xl;
            padding-right: Theme.spacing-xl;
            padding-top: Theme.spacing-xl;
            padding-bottom: Theme.spacing-lg;
            spacing: Theme.spacing-lg;

            // ─────────────────────────────────────────────
            // HERO: Quillon Graph logo + brand
            // ─────────────────────────────────────────────
            VerticalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-sm;

                HorizontalLayout {
                    alignment: center;

                    // Logo halo
                    Rectangle {
                        width: 128px;
                        height: 128px;
                        border-radius: 64px;
                        background: @radial-gradient(circle,
                            Theme.accent-cyan.with-alpha(0.18) 0%,
                            Theme.accent-purple.with-alpha(0.10) 60%,
                            transparent 100%);
                        drop-shadow-blur: 32px;
                        drop-shadow-color: Theme.accent-cyan.with-alpha(0.25);

                        // Quillon Graph logo (white-on-transparent shield, tinted cyan)
                        Image {
                            source: @image-url("icons/quillon-logo.png");
                            colorize: Theme.accent-cyan;
                            width: 96px;
                            height: 96px;
                            x: (parent.width - 96px) / 2;
                            y: (parent.height - 96px) / 2;
                            image-fit: contain;
                        }
                    }
                }

                Text {
                    text: "Quillon Graph";
                    color: Theme.text-primary;
                    font-size: Theme.font-3xl;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Quantum-Secure Wallet · Post-Quantum Signatures · Self-Custodial";
                    color: Theme.text-secondary;
                    font-size: Theme.font-md;
                    horizontal-alignment: center;
                }
            }

            // ─────────────────────────────────────────────
            // CREATE-VIEW: mnemonic display
            // ─────────────────────────────────────────────
            if root.show-create-view : Card {
                VerticalLayout {
                    padding: Theme.spacing-lg;
                    spacing: Theme.spacing-md;

                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        Icon {
                            source: @image-url("icons/shield-check.svg");
                            icon-color: Theme.accent-yellow;
                            width: Theme.icon-lg;
                            height: Theme.icon-lg;
                        }
                        Text {
                            text: "Your Recovery Phrase";
                            color: Theme.accent-yellow;
                            font-size: Theme.font-lg;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Text {
                        text: "Write these words down on paper and store them somewhere safe. Anyone with this phrase can take your funds. We cannot recover them for you.";
                        color: Theme.text-secondary;
                        font-size: Theme.font-sm;
                        wrap: word-wrap;
                    }

                    Rectangle {
                        height: 130px;
                        border-radius: Theme.radius-md;
                        background: Theme.bg-input;
                        border-width: 1px;
                        border-color: Theme.accent-yellow.with-alpha(0.3);

                        Text {
                            x: 14px;
                            y: 12px;
                            width: parent.width - 28px;
                            text: root.generated-mnemonic;
                            color: Theme.accent-cyan;
                            font-size: Theme.font-md;
                            font-weight: 500;
                            wrap: word-wrap;
                        }
                    }

                    QButton {
                        label: "I have saved my recovery phrase";
                        button-color: Theme.accent-green;
                        clicked => { root.confirm-created(); }
                    }
                }
            }

            // ─────────────────────────────────────────────
            // ACTION CARDS (initial view)
            // ─────────────────────────────────────────────
            if !root.show-create-view : VerticalLayout {
                spacing: Theme.spacing-md;

                // Action 1: Open with Browser (OAuth2) — primary path
                ActionCard {
                    title: "Sign in with Browser";
                    description: root.oauth-server-running
                        ? "OAuth2 — opens your browser to authorize this wallet (recommended)"
                        : "OAuth2 server unavailable on port " + root.oauth-port;
                    icon-source: @image-url("icons/scan-line.svg");
                    accent: Theme.accent-blue;
                    selected: root.active-action == 2;
                    clicked => {
                        root.active-action = root.active-action == 2 ? 0 : 2;
                    }
                }

                if root.active-action == 2 : Card {
                    VerticalLayout {
                        padding: Theme.spacing-md;
                        spacing: Theme.spacing-sm;

                        HorizontalLayout {
                            spacing: Theme.spacing-sm;
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 4px;
                                    background: root.oauth-server-running ? Theme.accent-green : Theme.accent-red;
                                    drop-shadow-blur: root.oauth-server-running ? 6px : 0px;
                                    drop-shadow-color: Theme.accent-green.with-alpha(0.5);
                                }
                            }
                            Text {
                                text: root.oauth-server-running ? "Authorization server running" : "Server stopped";
                                color: Theme.text-secondary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        QButton {
                            label: "Open browser to authorize";
                            button-color: Theme.accent-blue;
                            clicked => { root.open-oauth-browser(); }
                        }

                        Rectangle {
                            height: 28px;
                            border-radius: Theme.radius-sm;
                            background: Theme.bg-input;
                            border-width: 1px;
                            border-color: Theme.accent-cyan.with-alpha(0.2);

                            Text {
                                x: 10px;
                                text: "localhost:" + root.oauth-port + "/authorize";
                                color: Theme.text-muted;
                                font-size: Theme.font-xs;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                // Action 2: Create new wallet
                ActionCard {
                    title: "Create a new wallet";
                    description: "Generate a fresh 12-word recovery phrase and start fresh";
                    icon-source: @image-url("icons/sparkles.svg");
                    accent: Theme.accent-green;
                    clicked => { root.create-wallet(); }
                }

                // Action 3: Import existing
                ActionCard {
                    title: "Import existing wallet";
                    description: "Restore from a 12 or 24 word recovery phrase";
                    icon-source: @image-url("icons/wallet.svg");
                    accent: Theme.accent-purple;
                    selected: root.active-action == 1;
                    clicked => {
                        root.active-action = root.active-action == 1 ? 0 : 1;
                    }
                }

                if root.active-action == 1 : Card {
                    VerticalLayout {
                        padding: Theme.spacing-md;
                        spacing: Theme.spacing-sm;

                        Text {
                            text: "Recovery phrase";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                        }
                        QInput {
                            text <=> root.mnemonic-text;
                            placeholder: "word1 word2 word3 ...";
                            accepted(text) => { root.import-wallet(root.mnemonic-text); }
                        }
                        QButton {
                            label: "Import wallet";
                            button-color: Theme.accent-purple;
                            clicked => { root.import-wallet(root.mnemonic-text); }
                        }
                    }
                }
            }

            // ─────────────────────────────────────────────
            // SERVER URL (compact, advanced)
            // ─────────────────────────────────────────────
            Rectangle {
                height: 64px;
                border-radius: Theme.radius-md;
                background: Theme.bg-card.with-alpha(0.5);
                border-width: 1px;
                border-color: Theme.border;

                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;

                    VerticalLayout {
                        alignment: center;
                        Icon {
                            source: @image-url("icons/circle-dot.svg");
                            icon-color: Theme.accent-cyan;
                            width: Theme.icon-md;
                            height: Theme.icon-md;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        horizontal-stretch: 1;

                        Text {
                            text: "Node endpoint";
                            color: Theme.text-muted;
                            font-size: Theme.font-xs;
                        }
                        QInput {
                            text <=> root.server-url;
                            placeholder: "https://quillon.xyz";
                        }
                    }
                }
            }

            // ─────────────────────────────────────────────
            // ERROR / FOOTER
            // ─────────────────────────────────────────────
            if root.error-message != "" : Rectangle {
                height: self.preferred-height;
                border-radius: Theme.radius-md;
                background: Theme.accent-red.with-alpha(0.12);
                border-width: 1px;
                border-color: Theme.accent-red.with-alpha(0.4);

                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;

                    Icon {
                        source: @image-url("icons/x.svg");
                        icon-color: Theme.accent-red;
                        width: Theme.icon-md;
                        height: Theme.icon-md;
                    }
                    Text {
                        text: root.error-message;
                        color: Theme.accent-red;
                        font-size: Theme.font-sm;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }
            }

            // Footer (build / branding)
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-md;

                Text {
                    text: root.wallet-version;
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                }
                Text {
                    text: "·";
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                }
                Text {
                    text: "Q-NarwhalKnight · Post-Quantum Consensus";
                    color: Theme.text-muted;
                    font-size: Theme.font-xs;
                }
            }
        }
    }
}
