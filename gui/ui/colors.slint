// Q-NarwhalKnight Color Palette
export global Colors {
    // Primary quantum colors
    out property <color> quantum-primary: #00d4ff;
    out property <color> quantum-blue: #00d4ff;
    out property <color> quantum-purple: #a78bfa;
    out property <color> quantum-green: #10b981;
    out property <color> quantum-gold: #fbbf24;
    out property <color> quantum-red: #ff3366;

    // Background and surface colors - lighter for better contrast
    out property <color> background-primary: #1a1f2e;
    out property <color> background-secondary: #242938;
    out property <color> card-background: #2d3548cc;
    out property <color> card-bg: #2d3548cc;
    out property <color> glass-surface: #2d3548dd;

    // Text colors - brighter for better visibility
    out property <color> text-primary: #ffffff;
    out property <color> text-secondary: #cbd5e1;
    out property <color> text-muted: #94a3b8;
    
    // UI element colors
    out property <color> border-color: #334155;
    out property <color> hover-overlay: #ffffff11;
    out property <color> active-overlay: #ffffff22;
    
    // Status colors
    out property <color> success: #10b981;
    out property <color> warning: #f59e0b;
    out property <color> error: #ef4444;
    out property <color> info: #3b82f6;
    
    // Transparency
    out property <color> color-transparent: #00000000;
    out property <color> overlay-medium: #00000066;
}
