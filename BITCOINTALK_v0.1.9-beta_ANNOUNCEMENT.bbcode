[code]
--port <PORT>              HTTP API port (default: 8080)
--node-id <ID>             Node identifier
--bootstrap-peer <ADDR>    Bootstrap peer multiaddr
--db-path <PATH>           Database directory
--p2p-port <PORT>          P2P networking port
[/code]

